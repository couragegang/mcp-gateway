  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Contour (Prometheus)",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus-Prod",
          "value": "prometheus-prod"
        },
        "regex": "/Prometheus-(Test|Prod)/"
      },
      {
        "name": "job",
        "label": "job",
        "type": "constant",
        "query": "mcp",
        "current": {
          "text": "mcp",
          "value": "mcp"
        },
        "hide": 2
      }
    ]
  },
  "time": {
    "from": "now-6h",
